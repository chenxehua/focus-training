{
  "name": "@focus-training/miniapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "uni -p mp-weixin",
    "build": "uni build -p mp-weixin",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:wechat": "playwright test --config e2e/playwright.config.wechat.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "upload": "node scripts/upload.js upload",
    "preview": "node scripts/upload.js preview",
    "test:mp": "node scripts/test-automator.js",
    "test:games": "node scripts/test-games.js",
    "test:pages": "node scripts/test-pages.js",
    "test:pages:tabbar": "node scripts/test-pages.js tabbar",
    "test:pages:nav": "node scripts/test-pages.js navigation",
    "test:pages:games": "node scripts/test-pages.js games",
    "test:all": "playwright test && node scripts/test-automator.js",
    "test:auto": "node scripts/auto-test-fix.js",
    "test:auto:api": "node scripts/auto-test-fix.js --api",
    "test:auto:ui": "node scripts/auto-test-fix.js --ui",
    "test:auto:fix": "node scripts/auto-test-fix.js --fix",
    "test:ui": "node scripts/ui-tester.js",
    "test:verify": "node scripts/verify-pages.js",
    "test:run": "node scripts/run-tests.js",
    "test:run:api": "node scripts/run-tests.js --api",
    "test:run:pages": "node scripts/run-tests.js --pages",
    "test:run:ui": "node scripts/run-tests.js --ui",
    "test:run:all": "node scripts/run-tests.js --all",
    "test:run:fix": "node scripts/run-tests.js --fix"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-ui": "^1.4.28",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.3",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000820260430001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000820260430001",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.8.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^22.1.0",
    "miniprogram-automator": "^0.12.1",
    "miniprogram-ci": "^2.1.31",
    "sass": "^1.99.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "^0.34.0",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  }
}
