{
  "name": "expo-express-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:miniapp": "npm run dev:mp-weixin --workspace=packages/miniapp",
    "build:server": "npm run build --workspace=packages/server",
    "build:miniapp": "npm run build:mp-weixin --workspace=packages/miniapp",
    "install:all": "npm install"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
